@model IEnumerable<AltinZamani.Models.Partner>

@{
    ViewData["Title"] = "Partner ve Backlink Site Yönetimi";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-10">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold mb-0" style="color: #0d3b66;">
                    <i class="bi bi-link-45deg text-primary"></i> Partner / Backlink Site Yönetimi
                </h2>
                <a asp-controller="Admin" asp-action="CreatePartner" class="btn btn-primary fw-bold shadow-sm">
                    <i class="bi bi-plus-lg me-1"></i> Yeni Partner Ekle
                </a>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Sıra</th>
                                    <th>İkon / Resim</th>
                                    <th>Site Adı</th>
                                    <th>Rozet</th>
                                    <th>Durum</th>
                                    <th class="text-end pe-4">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-5 text-muted">
                                            <i class="bi bi-info-circle fs-1 d-block mb-3 text-secondary"></i>
                                            <h5 class="fw-bold">Henüz Partner Eklenmemiş</h5>
                                            <p class="mb-0">Sağ üstteki butonu kullanarak yeni bir Backlink site veya partner ekleyebilirsiniz.</p>
                                        </td>
                                    </tr>
                                }
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold text-muted">@item.Order</td>

                                        <td>
                                            @if (!string.IsNullOrEmpty(item.IconOrImageUrl) && item.IconOrImageUrl.StartsWith("bi-"))
                                            {
                                                <i class="bi @item.IconOrImageUrl fs-3" style="color:#0d3b66;"></i>
                                            }
                                            else if (!string.IsNullOrEmpty(item.IconOrImageUrl))
                                            {
                                                <img src="@item.IconOrImageUrl" alt="Logo" style="max-height: 40px; max-width: 80px; object-fit: contain;" class="img-fluid rounded" />
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-muted border">Yok</span>
                                            }
                                        </td>

                                        <td>
                                            <div class="fw-bold" style="color: #0d3b66;">@item.Name</div>
                                            @if (!string.IsNullOrEmpty(item.Url))
                                            {
                                                <a href="@item.Url" target="_blank" class="small text-decoration-none text-muted"><i class="bi bi-box-arrow-up-right me-1"></i>Linke Git</a>
                                            }
                                        </td>

                                        <td>
                                            @if (!string.IsNullOrEmpty(item.BadgeText))
                                            {
                                                <span class="badge bg-@(string.IsNullOrEmpty(item.BadgeColor) ? "primary" : item.BadgeColor)">@item.BadgeText</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">-</span>
                                            }
                                        </td>

                                        <td>
                                            @if (item.IsActive)
                                            {
                                                <span class="badge bg-success-subtle text-success border border-success-subtle"><i class="bi bi-check-circle me-1"></i>Aktif</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle"><i class="bi bi-dash-circle me-1"></i>Pasif</span>
                                            }
                                        </td>

                                        <td class="text-end pe-4">
                                            <div class="btn-group shadow-sm" role="group">
                                                <a asp-controller="Admin" asp-action="EditPartner" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Düzenle">
                                                    <i class="bi bi-pencil-square"></i> Düzenle
                                                </a>
                                                <form asp-controller="Admin" asp-action="DeletePartner" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('@item.Name isimli partneri kalıcı olarak silmek istediğinize emin misiniz?');">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <a asp-controller="Admin" asp-action="Settings" class="btn btn-link text-muted text-decoration-none fw-bold">
                    <i class="bi bi-arrow-left me-1"></i> Ayarlar Paneline Dön
                </a>
            </div>

        </div>
    </div>
</div>