@model AltinZamani.Models.Menu
@{
    ViewData["Title"] = "Sayfa Düzenle";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Sayfa İçeriğini Düzenle</h4>
        </div>
        <div class="card-body">
            <form asp-action="EditMenu" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Title" class="form-label">Menü Başlığı</label>
                        <input asp-for="Title" class="form-control" placeholder="Örn: Hakkımızda" required />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Slug" class="form-label">URL (Slug)</label>
                        <input asp-for="Slug" class="form-control" placeholder="hakkimizda" required />
                    </div>
                    <div class="col-md-2 mb-3">
                        <label asp-for="Order" class="form-label">Sıra</label>
                        <input asp-for="Order" type="number" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Content" class="form-label">Sayfa İçeriği</label>
                    <textarea asp-for="Content" id="editor" class="form-control"></textarea>
                </div>

                <div class="form-check mb-3">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox">
                    <label asp-for="IsActive" class="form-check-label">Menüde Gösterilsin mi?</label>
                </div>

                <button type="submit" class="btn btn-success px-4">Kaydet</button>
                <a asp-action="MenuList" class="btn btn-secondary">İptal</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/40.0.0/classic/ckeditor.js"></script>
    <script>
        ClassicEditor
            .create(document.querySelector('#editor'))
            .catch(error => { console.error(error); });
    </script>
}