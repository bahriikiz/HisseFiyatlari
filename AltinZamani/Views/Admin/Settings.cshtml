@model AltinZamani.Models.SiteSetting

@{
    ViewData["Title"] = "Sistem Ayarları";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="mb-4 fw-bold"><i class="bi bi-sliders"></i> Yönetim Paneli</h2>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> <strong>Başarılı!</strong> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <form asp-controller="Admin" asp-action="Settings" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="card shadow border-0 mb-4">
                    <div class="card-header bg-primary text-white py-3">
                        <h5 class="mb-0"><i class="bi bi-search"></i> SEO ve Google Ayarları</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label asp-for="MetaTitle" class="form-label fw-bold">Site Başlığı (Title)</label>
                            <input asp-for="MetaTitle" class="form-control" placeholder="Google'da görünecek ana başlık" />
                            <small class="text-muted">Örn: Altın Zamanı - Canlı Altın ve Döviz Fiyatları</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MetaDescription" class="form-label fw-bold">Site Açıklaması (Description)</label>
                            <textarea asp-for="MetaDescription" class="form-control" rows="3" placeholder="Sitenizi anlatan kısa bir özet yazın..."></textarea>
                            <small class="text-muted">Arama sonuçlarında başlığın altında çıkan açıklama metni.</small>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="MetaKeywords" class="form-label fw-bold">Anahtar Kelimeler</label>
                                <input asp-for="MetaKeywords" class="form-control" placeholder="altın, döviz, canlı kur" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="AnalyticsCode" class="form-label fw-bold">Google Analytics (G-XXXXX)</label>
                                <input asp-for="AnalyticsCode" class="form-control" placeholder="G-12345678" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card shadow border-0 mb-4">
                    <div class="card-header bg-dark text-white py-3">
                        <h5 class="mb-0"><i class="bi bi-gear-fill"></i> Otomasyon Ayarları</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="ApiFetchIntervalInHours" class="form-label fw-bold">API Çekme Sıklığı</label>
                                <div class="input-group">
                                    <input asp-for="ApiFetchIntervalInHours" type="number" class="form-control" min="1" max="24" />
                                    <span class="input-group-text">Saat</span>
                                </div>
                            </div>
                           
                            <div class="col-md-4 mb-3">
                                <label asp-for="DataRetentionDays" class="form-label fw-bold">Veri Saklama</label>
                                <div class="input-group">
                                    <input asp-for="DataRetentionDays" type="number" class="form-control" min="1" max="30" />
                                    <span class="input-group-text">Gün</span>
                                </div>
                            </div>
                        </div>
                        <small class="text-muted fst-italic">Not: API sıklığı değiştiğinde Hangfire görevleri anlık olarak güncellenir.</small>
                    </div>
                </div>

                <div class="card shadow border-0 mb-4">
                    <div class="card-header bg-secondary text-white py-3">
                        <h5 class="mb-0"><i class="bi bi-share-fill"></i> İletişim ve Sosyal Medya</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <label asp-for="ContactEmail" class="form-label fw-bold">İletişim E-posta</label>
                            <input asp-for="ContactEmail" class="form-control" type="email" />
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="InstagramUrl" class="form-label fw-bold">Instagram URL</label>
                                <input asp-for="InstagramUrl" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="TwitterUrl" class="form-label fw-bold">Twitter URL</label>
                                <input asp-for="TwitterUrl" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-success btn-lg shadow-sm">
                        <i class="bi bi-save"></i> Tüm Ayarları Kaydet ve Yayına Al
                    </button>
                    <a href="/" class="btn btn-link text-muted">Ana Sayfaya Dön</a>
                </div>
            </form>
        </div>
    </div>
</div>