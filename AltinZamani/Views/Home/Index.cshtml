@model List<AltinZamani.Models.MarketData>

@{
    ViewData["Title"] = "Ana Sayfa - Canlı Piyasalar";

    // Gelen verileri daha kolay ekrana basmak için kategorilere ayırıyoruz
    var kurlar = Model.Where(m => m.Name == "USD" || m.Name == "EUR" || m.Name == "GBP").ToList();
    var temelAltinlar = Model.Where(m => m.Name == "gram-altin" || m.Name == "ceyrek-altin" || m.Name == "ons").ToList();
    var digerAltinlar = Model.Where(m => !kurlar.Contains(m) && !temelAltinlar.Contains(m)).OrderByDescending(m => m.LastPrice).ToList();
}

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold text-warning">Altın Zamanı</h1>
    <p class="lead">En güncel canlı altın ve döviz fiyatları</p>
</div>

@if (!Model.Any())
{
    <div class="alert alert-warning text-center">
        Şu anda piyasa verisi bulunamadı. Lütfen daha sonra tekrar deneyin.
    </div>
}
else
{
    <div class="row mb-4">
        @foreach (var item in temelAltinlar.Concat(kurlar))
        {
            // Değişim yönüne göre renk belirliyoruz (Yeşil veya Kırmızı)
            string colorClass = item.ChangePercentage >= 0 ? "text-success" : "text-danger";
            string iconClass = item.ChangePercentage >= 0 ? "▲" : "▼";
            // İsimleri biraz daha okunaklı yapalım
            string displayName = item.Name.ToUpper().Replace("-", " ");

            <div class="col-md-4 col-sm-6 mb-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body text-center">
                        <h5 class="card-title text-muted">@displayName</h5>
                        <h2 class="card-text fw-bold">@item.LastPrice.ToString("N4") ₺</h2>
                        <p class="card-text @colorClass fw-bold fs-5">
                            @iconClass %@item.ChangePercentage.ToString("N2")
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card shadow border-0">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Tüm Piyasa Verileri (Altın & Diğer)</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Birim Adı</th>
                            <th class="text-end">Son Fiyat</th>
                            <th class="text-end">Günlük Değişim</th>
                            <th class="text-end">Son Güncelleme</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in digerAltinlar)
                        {
                            string colorClass = item.ChangePercentage >= 0 ? "text-success" : "text-danger";
                            string displayName = item.Name.ToUpper().Replace("-", " ");

                            <tr>
                                <td class="fw-bold">@displayName</td>
                                <td class="text-end fw-bold">@item.LastPrice.ToString("N4")</td>
                                <td class="text-end @colorClass fw-bold">
                                    %@item.ChangePercentage.ToString("N2")
                                </td>
                                <td class="text-end text-muted">@item.RecordDate.ToString("HH:mm:ss")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}