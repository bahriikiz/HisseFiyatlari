@using AltinZamani.Data
@inject ApplicationDbContext _context
@{
    // Veritabanından ayarları çekiyoruz, eğer henüz ayar yoksa boş bir model oluşturuyoruz
    var settings = _context.SiteSettings.FirstOrDefault() ?? new AltinZamani.Models.SiteSetting();
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@settings.MetaTitle</title>
    <meta name="description" content="@settings.MetaDescription" />
    <meta name="keywords" content="@settings.MetaKeywords" />
    <meta name="author" content="Altın Zamanı" />

    @if (!string.IsNullOrEmpty(settings.AnalyticsCode))
    {
        <script async src="https://www.googletagmanager.com/gtag/js?id=@settings.AnalyticsCode"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '@settings.AnalyticsCode');
        </script>
    }

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-warning" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-currency-exchange"></i> Altın Zamanı
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-collapse collapse d-sm-inline-flex justify-content-between list-unstyled m-0">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-secondary" asp-controller="Admin" asp-action="Settings">
                                <i class="bi bi-person-lock"></i> Yönetim
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light mt-auto py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-6 text-center text-md-start">
                    <span class="fw-bold">© @DateTime.Now.Year - Altın Zamanı</span>
                    <p class="small mb-0">@settings.FooterText</p>
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <div class="social-links mb-2">
                        @if (!string.IsNullOrEmpty(settings.InstagramUrl))
                        {
                            <a href="@settings.InstagramUrl" target="_blank" class="text-danger fs-4 me-3"><i class="bi bi-instagram"></i></a>
                        }
                        @if (!string.IsNullOrEmpty(settings.TwitterUrl))
                        {
                            <a href="@settings.TwitterUrl" target="_blank" class="text-info fs-4 me-3"><i class="bi bi-twitter-x"></i></a>
                        }
                        @if (!string.IsNullOrEmpty(settings.FacebookUrl))
                        {
                            <a href="@settings.FacebookUrl" target="_blank" class="text-primary fs-4"><i class="bi bi-facebook"></i></a>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(settings.ContactEmail))
                    {
                        <small><i class="bi bi-envelope-at"></i> @settings.ContactEmail</small>
                    }
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>