@using AltinZamani.Data
@inject ApplicationDbContext _context
@{
    var settings = _context.SiteSettings.FirstOrDefault() ?? new AltinZamani.Models.SiteSetting();
    bool isAdminPage = ViewContext.RouteData.Values["controller"]?.ToString() == "Admin";
    string lang = Context.Request.Cookies["SiteLanguage"] ?? "tr";
    bool isEn = lang == "en";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@settings.MetaTitle</title>
    <meta name="description" content="@settings.MetaDescription" />
    <meta name="keywords" content="@settings.MetaKeywords" />
    <meta name="author" content="Altın Zamanı" />

    @if (!isAdminPage && !string.IsNullOrEmpty(settings.AdsenseCode))
    {
        @Html.Raw(settings.AdsenseCode)
    }

    @if (!string.IsNullOrEmpty(settings.AnalyticsCode))
    {
        <script async src="https://www.googletagmanager.com/gtag/js?id=@settings.AnalyticsCode"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', '@settings.AnalyticsCode');
        </script>
    }

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        .kurumsal-menu .nav-link {
            color: #0d3b66 !important;
            font-weight: 600;
            font-size: 0.9rem;
            letter-spacing: 0.5px;
            padding: 0.5rem 1rem !important;
            transition: color 0.3s ease;
        }

            .kurumsal-menu .nav-link:hover {
                color: #ffc107 !important;
            }

        .kurumsal-logo-yazi {
            color: #0d3b66;
            font-weight: 900;
            font-size: 1.5rem;
            letter-spacing: -1px;
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100 bg-light">

    <header class="bg-white border-bottom shadow-sm mb-4">
        <div class="container-fluid px-lg-5">
            <nav class="navbar navbar-expand-lg navbar-light bg-white py-3">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <div class="bg-primary text-white d-flex align-items-center justify-content-center me-2" style="width: 40px; height: 40px; border-radius: 4px;">
                        <i class="bi bi-graph-up-arrow fs-5"></i>
                    </div>
                    <span class="kurumsal-logo-yazi">ALTIN<span class="text-warning">ZAMANI</span></span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Menüyü aç">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end kurumsal-menu">
                    <ul class="navbar-nav align-items-center">

                        @{
                            var dynamicMenus = _context.Menus.Where(m => m.IsActive).OrderBy(m => m.Order).ToList();
                        }

                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">@(isEn ? "MARKETS" : "PİYASALAR")</a>
                        </li>

                        @foreach (var menu in dynamicMenus)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Page" asp-route-slug="@menu.Slug">
                                    @menu.Title
                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link fw-bold" asp-area="" asp-controller="Home" asp-action="About">
                                <i class="bi bi-info-circle me-1"></i>@(isEn ? "ABOUT US" : "HAKKIMIZDA")
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link fw-bold" asp-area="" asp-controller="Home" asp-action="Contact" style="color: #0d6efd !important;">
                                <i class="bi bi-envelope-at me-1"></i>@(isEn ? "CONTACT" : "İLETİŞİM")
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-muted" asp-controller="Admin" asp-action="Settings">YÖNETİM</a>
                        </li>

                        @if (User.Identity is { IsAuthenticated: true })
                        {
                            <li class="nav-item ms-lg-2">
                                <a class="nav-link text-danger fw-bold" asp-controller="Admin" asp-action="Logout" title="Çıkış Yap">
                                    <i class="bi bi-power"></i> ÇIKIŞ
                                </a>
                            </li>
                        }

                        <li class="nav-item ms-lg-3">
                            <a class="nav-link" href="#" style="font-size: 1.1rem;" aria-label="Sitede Ara"><i class="bi bi-search"></i></a>
                        </li>

                        <li class="nav-item ms-lg-1">
                            @if (isEn)
                            {
                                <a class="nav-link fw-bold" asp-controller="Home" asp-action="SetLanguage" asp-route-culture="tr" asp-route-returnUrl="@Context.Request.Path" style="color: #e63946 !important;">TR</a>
                            }
                            else
                            {
                                <a class="nav-link fw-bold" asp-controller="Home" asp-action="SetLanguage" asp-route-culture="en" asp-route-returnUrl="@Context.Request.Path" style="color: #0d6efd !important;">EN</a>
                            }
                        </li>
                    </ul>
                </div>
            </nav>
        </div>
    </header>

    <div class="container-fluid flex-grow-1 px-lg-5">

        @if (!isAdminPage && !string.IsNullOrEmpty(settings.TopAdCode))
        {
            <div class="row mb-3 text-center">
                <div class="col-12">@Html.Raw(settings.TopAdCode)</div>
            </div>
        }

        <div class="row">
            <aside class="col-xl-2 d-none d-xl-block text-center" aria-label="Sol Reklam Alanı">
                <div class="sticky-top" style="top: 100px;">
                    @if (!isAdminPage && !string.IsNullOrEmpty(settings.LeftAdCode))
                    {
                        @Html.Raw(settings.LeftAdCode)
                    }
                </div>
            </aside>

            <main role="main" class="col-12 col-xl-8 pb-3">
                @RenderBody()
            </main>

            <aside class="col-xl-2 d-none d-xl-block text-center" aria-labelledby="sponsor-heading">
                <div class="sticky-top" style="top: 100px;">
                    <h6 id="sponsor-heading" class="text-muted border-bottom pb-2 mb-3">SPONSORLARIMIZ</h6>

                    @{
                        var activeSponsors = _context.Sponsors.Where(s => s.IsActive == true).OrderBy(s => s.Order).ToList();
                    }

                    @foreach (var sponsor in activeSponsors)
                    {
                        <div class="card mb-3 border-0 shadow-sm text-center p-2">
                            <a href="@sponsor.WebsiteLink" target="_blank" title="@sponsor.Name" class="text-decoration-none">
                                @if (!string.IsNullOrEmpty(sponsor.LogoUrl))
                                {
                                    <img src="@sponsor.LogoUrl" class="img-fluid mb-2 rounded" alt="@sponsor.Name" style="max-height: 80px;">
                                }
                                <div class="small fw-bold text-dark">@sponsor.Name</div>
                            </a>
                        </div>
                    }

                    @if (!isAdminPage && !string.IsNullOrEmpty(settings.RightAdCode))
                    {
                        <div class="mt-4">@Html.Raw(settings.RightAdCode)</div>
                    }
                </div>
            </aside>
        </div>
    </div>

    <footer class="border-top footer text-muted bg-white mt-auto py-4">
        @if (!isAdminPage && !string.IsNullOrEmpty(settings.BannerAdCode))
        {
            <div class="container-fluid text-center mb-4">
                @Html.Raw(settings.BannerAdCode)
            </div>
        }

        <div class="container-fluid px-lg-5">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    <span class="fw-bold" style="color:#0d3b66;">© @DateTime.Now.Year - Altın Zamanı</span>
                    @if (!string.IsNullOrEmpty(settings.FooterText))
                    {
                        <p class="small mb-0 mt-1">@settings.FooterText</p>
                    }
                </div>
                <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
                    <div class="social-links mb-2">
                        @if (settings.IsInstagramActive && !string.IsNullOrEmpty(settings.InstagramUrl))
                        {
                            <a href="@settings.InstagramUrl" target="_blank" class="text-danger fs-4 me-3" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                        }

                        @if (settings.IsTwitterActive && !string.IsNullOrEmpty(settings.TwitterUrl))
                        {
                            <a href="@settings.TwitterUrl" target="_blank" class="text-dark fs-4 me-3" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                        }

                        @if (settings.IsFacebookActive && !string.IsNullOrEmpty(settings.FacebookUrl))
                        {
                            <a href="@settings.FacebookUrl" target="_blank" style="color:#0d6efd;" class="fs-4" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(settings.ContactEmail))
                    {
                        <div class="small text-muted">
                            <i class="bi bi-envelope-at me-1"></i>
                            <a href="mailto:@settings.ContactEmail" class="text-decoration-none text-muted">@settings.ContactEmail</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>