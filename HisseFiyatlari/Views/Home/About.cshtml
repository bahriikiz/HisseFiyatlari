@{
    ViewData["Title"] = "Hakkımızda";
    string lang = Context.Request.Cookies["SiteLanguage"] ?? "tr";
    bool isEn = lang == "en";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h2 class="display-5 fw-bold" style="color: #0d3b66;">
            @(isEn ? "STOCK" : "HİSSE") <span class="text-success">@(isEn ? "PRICES" : "FİYATLARI")</span>
        </h2>
        <p class="lead text-muted">
            @(isEn ? "Track live stock market data, shares, and indices instantly." : "Canlı borsa verilerini, hisse senetlerini ve endeksleri anlık takip edin.")
        </p>
    </div>

    <div class="row g-4 text-center">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 py-4" style="border-radius: 15px;">
                <div class="card-body">
                    <i class="bi bi-activity text-success mb-3" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">@(isEn ? "Live Tracking" : "Canlı Takip")</h5>
                    <p class="text-muted small mb-0">@(isEn ? "Follow BIST data and stocks second by second." : "BİST verilerini ve hisse senetlerini saniyesi saniyesine takip edin.")</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 py-4" style="border-radius: 15px;">
                <div class="card-body">
                    <i class="bi bi-shield-check text-primary mb-3" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">@(isEn ? "Reliable Data" : "Güvenilir Veri")</h5>
                    <p class="text-muted small mb-0">@(isEn ? "Our data is provided instantly from reliable global financial sources." : "Verilerimiz global ve güvenilir finans kaynaklarından anlık olarak sağlanır.")</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 py-4" style="border-radius: 15px;">
                <div class="card-body">
                    <i class="bi bi-phone text-warning mb-3" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">@(isEn ? "Mobile Friendly" : "Mobil Uyumlu")</h5>
                    <p class="text-muted small mb-0">@(isEn ? "Watch the stock market seamlessly from any device you want." : "İstediğiniz her cihazdan borsayı ve portföyünüzü kesintisiz izleyin.")</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 py-4" style="border-radius: 15px;">
                <div class="card-body">
                    <i class="bi bi-gift text-danger mb-3" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">@(isEn ? "Free" : "Ücretsiz")</h5>
                    <p class="text-muted small mb-0">@(isEn ? "All our live market features are completely free." : "Tüm canlı borsa özelliklerimiz ve analiz araçlarımız tamamen ücretsizdir.")</p>
                </div>
            </div>
        </div>
    </div>
</div>