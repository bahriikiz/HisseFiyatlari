@model Dictionary<DateTime, List<HisseFiyatlari.Models.MarketData>>

@{
    ViewData["Title"] = "Ana Sayfa - Canlı Borsa & Hisse Fiyatları";
    var today = DateTime.Now.Date;
    var latestData = (Model != null && Model.Any()) ? Model.First().Value : new List<HisseFiyatlari.Models.MarketData>();

    // Özet kartlar için majör endeks ve hisseleri ayırıyoruz
    var endeksler = latestData.Where(m => m.Name == "XU100" || m.Name == "XU030").ToList();
    var popülerHisseler = latestData.Where(m => m.Name == "THYAO" || m.Name == "ASELS" || m.Name == "TUPRS").ToList();

    string aktifSembol = "₺";
    string lang = Context.Request.Cookies["SiteLanguage"] ?? "tr";
    bool isEn = lang == "en";

    string GetTabLabel(DateTime date)
    {
        if (date == today) return isEn ? "Today" : "Bugün";
        if (date == today.AddDays(-1)) return isEn ? "Yesterday" : "Dün";
        return date.ToString("dd.MM.yyyy");
    }

    // Hisse kodlarını tam isimlere çeviren metot
    string TranslateName(string? name)
    {
        if (string.IsNullOrEmpty(name)) return "";
        return name.ToUpper() switch
        {
            "XU100" => "BIST 100",
            "XU030" => "BIST 30",
            "THYAO" => "Türk Hava Yolları",
            "ASELS" => "Aselsan",
            "TUPRS" => "Tüpraş",
            "EREGL" => "Erdemir",
            "GARAN" => "Garanti BBVA",
            "ISCTR" => "İş Bankası (C)",
            "YKBNK" => "Yapı Kredi",
            "AKBNK" => "Akbank",
            "SISE" => "Şişecam",
            "BIMAS" => "BİM Mağazalar",
            _ => name.ToUpper()
        };
    }
}

<div class="text-center mb-4">
    <h1 class="display-4 fw-bold text-success">@(isEn ? "Stock Price" : "Hisse Fiyatları")</h1>
    <p class="lead">@(isEn ? "Live Borsa Istanbul stock prices and indices" : "Canlı Borsa İstanbul hisse senedi ve endeks verileri")</p>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning text-center">
        @(isEn ? "No market data available." : "Şu anda borsa verisi bulunamadı.")
    </div>
}
else
{
    <div class="row mb-5">
        <div class="col-12">
            <div class="card shadow border-0">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-dark">@(isEn ? "BIST 100 Index - Last 24 Hours" : "BIST 100 Endeksi - Son 24 Saat")</h5>
                    <span class="badge bg-danger shadow-sm heartbeat-animation"><i class="bi bi-broadcast me-1"></i>@(isEn ? "Live" : "Canlı Takip")</span>
                </div>
                <div class="card-body">
                    <canvas id="stockChart" style="max-height: 350px; width: 100%;"></canvas>
                </div>
            </div>
        </div>
    </div>

    @* Özet Kartlar *@
    <div class="row mb-4">
        @foreach (var item in endeksler.Concat(popülerHisseler))
        {
            string colorClass = item.ChangePercentage >= 0 ? "text-success" : "text-danger";
            string iconClass = item.ChangePercentage >= 0 ? "▲" : "▼";
            <div class="col-md-4 col-sm-6 mb-3">
                <div class="card shadow-sm border-0 h-100 border-start border-4 @(item.ChangePercentage >= 0 ? "border-success" : "border-danger")">
                    <div class="card-body text-center">
                        <h6 class="text-muted mb-1">@TranslateName(item.Name) (@item.Name)</h6>
                        <h2 class="card-text fw-bold mb-0">@aktifSembol@item.LastPrice.ToString("N2")</h2>
                        <p class="card-text @colorClass fw-bold">@iconClass %@item.ChangePercentage.ToString("N2")</p>
                    </div>
                </div>
            </div>
        }
    </div>

    @* Detaylı Liste Sekmeleri *@
    <div class="card shadow border-0 mb-4">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
            <h5 class="mb-0"><i class="bi bi-bar-chart-fill me-2"></i>@(isEn ? "Market Analysis" : "Piyasa Analizi")</h5>
            <button onclick="exportToExcel()" class="btn btn-sm btn-success fw-bold"><i class="bi bi-file-earmark-excel me-1"></i> Excel</button>
        </div>

        <div class="card-header bg-white border-bottom-0 pt-3 pb-0 px-4">
            <ul class="nav nav-tabs" id="marketTabs">
                @{
                    int tabIndex = 0;
                }
                @foreach (var dateKey in Model.Keys)
                {
                    <li class="nav-item">
                        <button class="nav-link @(tabIndex == 0 ? "active" : "") fw-bold px-4" id="tab-@dateKey.ToString("yyyyMMdd")-tab" data-bs-toggle="tab" data-bs-target="#tab-@dateKey.ToString("yyyyMMdd")" type="button">@GetTabLabel(dateKey)</button>
                    </li>
                    tabIndex++;
                }
            </ul>
        </div>

        <div class="card-body p-0">
            <div class="tab-content">
                @{
                    tabIndex = 0;
                }
                @foreach (var kvp in Model)
                {
                    <div class="tab-pane fade @(tabIndex == 0 ? "show active" : "")" id="tab-@kvp.Key.ToString("yyyyMMdd")">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">@(isEn ? "Stock / Ticker" : "Hisse Senedi")</th>
                                        <th class="text-end">@(isEn ? "Price" : "Son Fiyat")</th>
                                        <th class="text-end">@(isEn ? "Daily Change" : "Değişim")</th>
                                        <th class="text-end pe-4">@(isEn ? "Time" : "Saat")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in kvp.Value)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold">@TranslateName(item.Name) <small class="text-muted">(@item.Name)</small></td>
                                            <td class="text-end fw-bold text-primary">@item.LastPrice.ToString("N2") @aktifSembol</td>
                                            <td class="text-end @(item.ChangePercentage >= 0 ? "text-success" : "text-danger") fw-bold">
                                                @(item.ChangePercentage >= 0 ? "+" : "")@item.ChangePercentage.ToString("N2")%
                                            </td>
                                            <td class="text-end text-muted pe-4">@item.RecordDate.ToString("HH:mm")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    tabIndex++;
                }
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const chartCanvas = document.getElementById('stockChart');
            if(!chartCanvas) return;

            // XU100 grafiği için GetChartData action'ına istek atıyoruz
            fetch('/Home/GetChartData?name=XU100')
                .then(response => response.json())
                .then(data => {
                    const ctx = chartCanvas.getContext('2d');
                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: data.map(item => item.time),
                            datasets: [{
                                label: 'BIST 100 Endeksi',
                                data: data.map(item => item.price),
                                borderColor: '#198754', // Borsa yeşili
                                backgroundColor: 'rgba(25, 135, 84, 0.1)',
                                fill: true,
                                tension: 0.3
                            }]
                        },
                        options: { responsive: true, maintainAspectRatio: false }
                    });
                });
        });

        function exportToExcel() {
            const activeTable = document.querySelector('.tab-pane.active table');
            const wb = XLSX.utils.table_to_book(activeTable);
            XLSX.writeFile(wb, "Borsa_Verileri.xlsx");
        }
    </script>
}