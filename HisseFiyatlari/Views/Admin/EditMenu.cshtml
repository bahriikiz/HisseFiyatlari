@model HisseFiyatlari.Models.Menu
@{
    ViewData["Title"] = "Menü ve Sayfa Düzenle";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-success text-white py-3 rounded-top-4">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i> Menü ve Sayfa İçeriği Düzenle</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="EditMenu" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="row">
                            <div class="col-md-5 mb-3">
                                <label asp-for="Title" class="form-label fw-bold">Menü Başlığı</label>
                                <input asp-for="Title" class="form-control" placeholder="Örn: Hakkımızda" required />
                                <span asp-validation-for="Title" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="Slug" class="form-label fw-bold">URL (Slug)</label>
                                <input asp-for="Slug" class="form-control" placeholder="hakkimizda" required />
                                <span asp-validation-for="Slug" class="text-danger small"></span>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label asp-for="Order" class="form-label fw-bold">Sıra</label>
                                <input asp-for="Order" type="number" class="form-control" />
                            </div>
                        </div>

                        <div class="card bg-light border-0 rounded-3 mb-4 p-3">
                            <label asp-for="Content" class="form-label fw-bold text-success"><i class="bi bi-card-text me-1"></i> Sayfa İçeriği (Opsiyonel)</label>
                            <textarea asp-for="Content" id="editor" class="form-control"></textarea>
                            <small class="text-muted mt-2 d-block">Bu menüye tıklandığında açılacak sayfanın içeriğini buradan tasarlayabilirsiniz. Sadece dışarıya giden bir link olacaksa burayı boş bırakabilirsiniz.</small>
                        </div>

                        <div class="mb-4 d-flex align-items-end pb-2">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input fs-5" type="checkbox" id="isActiveSwitchEdit">
                                <label class="form-check-label ms-2 pt-1 fw-bold text-success" for="isActiveSwitchEdit">Menüde Gösterilsin mi?</label>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="MenuList" class="btn btn-outline-secondary fw-bold">
                                <i class="bi bi-arrow-left me-1"></i> İptal ve Geri Dön
                            </a>
                            <button type="submit" class="btn btn-success fw-bold px-4">
                                <i class="bi bi-save me-1"></i> İçeriği Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/40.0.0/classic/ckeditor.js"></script>
    <script>
        ClassicEditor
            .create(document.querySelector('#editor'))
            .catch(error => { console.error(error); });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}