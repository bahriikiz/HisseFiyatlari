@model HisseFiyatlari.Models.Partner

@{
    ViewData["Title"] = "Partner Düzenle";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-primary text-white py-3 rounded-top-4">
                    <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i> Partner / Backlink Site Düzenle</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="EditPartner" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />

                        <input type="hidden" asp-for="IconOrImageUrl" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label fw-bold"></label>
                                <input asp-for="Name" class="form-control" required />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Url" class="form-label fw-bold"></label>
                                <input asp-for="Url" class="form-control" placeholder="Örn: https://site.com" />
                            </div>
                        </div>

                        <div class="card bg-light border-0 rounded-3 mb-4 p-3">
                            <h6 class="fw-bold mb-3"><i class="bi bi-image me-2"></i>Görsel veya İkon Ayarı</h6>

                            @if (!string.IsNullOrEmpty(Model.IconOrImageUrl))
                            {
                                <div class="mb-3 p-2 bg-white rounded border d-inline-block">
                                    <span class="small text-muted d-block mb-1">Mevcut Görsel:</span>
                                    @if (Model.IconOrImageUrl.StartsWith("bi-"))
                                    {
                                        <i class="bi @Model.IconOrImageUrl fs-2 text-primary"></i>
                                    }
                                    else
                                    {
                                        <img src="@Model.IconOrImageUrl" style="max-height: 40px;" class="img-fluid" />
                                    }
                                </div>
                            }

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="ImageFile" class="form-label fw-bold small text-muted">Yeni Bilgisayardan Seç (İsteğe Bağlı)</label>
                                    <input asp-for="ImageFile" type="file" class="form-control form-control-sm" accept=".jpg,.jpeg,.png,.svg,.ico" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="IconOrImageUrlInput" class="form-label fw-bold small text-muted">VEYA İkon Adı (Örn: bi-bank)</label>
                                    <input type="text" id="IconOrImageUrlInput" name="IconOrImageUrl" value="@Model.IconOrImageUrl" class="form-control form-control-sm" placeholder="bi-graph-up-arrow" />
                                </div>
                            </div>
                            <small class="text-muted" style="font-size: 0.8rem;">Not: Yeni bir dosya seçerseniz mevcut görsel/ikon silinir ve yeni dosya kullanılır.</small>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="BadgeText" class="form-label fw-bold"></label>
                                <input asp-for="BadgeText" class="form-control" placeholder="Örn: Backlink Site" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="BadgeColor" class="form-label fw-bold"></label>
                                <select asp-for="BadgeColor" class="form-select">
                                    <option value="primary">Mavi (Primary)</option>
                                    <option value="success">Yeşil (Success)</option>
                                    <option value="warning">Sarı (Warning)</option>
                                    <option value="danger">Kırmızı (Danger)</option>
                                    <option value="info">Açık Mavi (Info)</option>
                                    <option value="secondary">Gri (Secondary)</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Order" class="form-label fw-bold"></label>
                                <input asp-for="Order" type="number" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-4 d-flex align-items-end pb-2">
                                <div class="form-check form-switch">
                                    <input asp-for="IsActive" class="form-check-input fs-5" type="checkbox" id="isActiveSwitchEdit">
                                    <label class="form-check-label ms-2 pt-1 fw-bold text-success" for="isActiveSwitchEdit">Sitede Aktif (Görünsün)</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="PartnerList" class="btn btn-outline-secondary fw-bold">
                                <i class="bi bi-arrow-left me-1"></i> Geri Dön
                            </a>
                            <button type="submit" class="btn btn-primary fw-bold px-4">
                                <i class="bi bi-save me-1"></i> Değişiklikleri Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}